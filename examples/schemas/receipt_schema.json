{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Receipt Extraction Schema",
  "description": "Schema for extracting structured data from purchase receipts",
  "properties": {
    "merchant_name": {
      "type": "string",
      "description": "Name of the merchant/store"
    },
    "merchant_address": {
      "type": "string",
      "description": "Physical address of the merchant location"
    },
    "merchant_phone": {
      "type": "string",
      "description": "Merchant contact phone number"
    },
    "receipt_number": {
      "type": "string",
      "description": "Receipt or transaction identifier"
    },
    "transaction_date": {
      "type": "string",
      "description": "Date of transaction (YYYY-MM-DD format)"
    },
    "transaction_time": {
      "type": "string",
      "description": "Time of transaction (HH:MM:SS format)"
    },
    "items": {
      "type": "array",
      "description": "Purchased items",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Item name or description"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of items purchased",
            "minimum": 1
          },
          "unit_price": {
            "type": "number",
            "description": "Price per unit",
            "minimum": 0
          },
          "total_price": {
            "type": "number",
            "description": "Total price for this item",
            "minimum": 0
          }
        },
        "required": ["name", "total_price"]
      }
    },
    "subtotal": {
      "type": "number",
      "description": "Subtotal before tax",
      "minimum": 0
    },
    "tax_amount": {
      "type": "number",
      "description": "Total tax amount",
      "minimum": 0
    },
    "discount_amount": {
      "type": "number",
      "description": "Total discount applied",
      "minimum": 0
    },
    "tip_amount": {
      "type": "number",
      "description": "Tip or gratuity amount",
      "minimum": 0
    },
    "total_amount": {
      "type": "number",
      "description": "Final total paid",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "description": "Currency code (ISO 4217)",
      "default": "USD"
    },
    "payment_method": {
      "type": "string",
      "description": "Payment method used",
      "enum": ["Cash", "Credit Card", "Debit Card", "Mobile Payment", "Other"]
    },
    "card_last_four": {
      "type": "string",
      "description": "Last 4 digits of card number (if card payment)",
      "pattern": "^[0-9]{4}$"
    },
    "cashier_name": {
      "type": "string",
      "description": "Name of the cashier who processed the transaction"
    }
  },
  "required": [
    "merchant_name",
    "transaction_date",
    "items",
    "total_amount"
  ]
}
