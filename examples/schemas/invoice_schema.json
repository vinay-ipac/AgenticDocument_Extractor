{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Invoice Extraction Schema",
  "description": "Schema for extracting structured data from invoices",
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Unique invoice identifier"
    },
    "invoice_date": {
      "type": "string",
      "description": "Date when the invoice was issued (YYYY-MM-DD format)"
    },
    "due_date": {
      "type": "string",
      "description": "Payment due date (YYYY-MM-DD format)"
    },
    "vendor": {
      "type": "object",
      "description": "Vendor/seller information",
      "properties": {
        "name": {
          "type": "string",
          "description": "Vendor company name"
        },
        "address": {
          "type": "string",
          "description": "Vendor street address"
        },
        "city": {
          "type": "string",
          "description": "Vendor city"
        },
        "state": {
          "type": "string",
          "description": "Vendor state/province"
        },
        "postal_code": {
          "type": "string",
          "description": "Vendor postal/ZIP code"
        },
        "country": {
          "type": "string",
          "description": "Vendor country"
        },
        "tax_id": {
          "type": "string",
          "description": "Vendor tax identification number (GST/VAT/TIN)"
        },
        "phone": {
          "type": "string",
          "description": "Vendor contact phone number"
        },
        "email": {
          "type": "string",
          "description": "Vendor contact email address"
        }
      },
      "required": ["name"]
    },
    "customer": {
      "type": "object",
      "description": "Customer/buyer information",
      "properties": {
        "name": {
          "type": "string",
          "description": "Customer company or individual name"
        },
        "address": {
          "type": "string",
          "description": "Customer street address"
        },
        "city": {
          "type": "string",
          "description": "Customer city"
        },
        "state": {
          "type": "string",
          "description": "Customer state/province"
        },
        "postal_code": {
          "type": "string",
          "description": "Customer postal/ZIP code"
        },
        "country": {
          "type": "string",
          "description": "Customer country"
        },
        "phone": {
          "type": "string",
          "description": "Customer contact phone number"
        },
        "email": {
          "type": "string",
          "description": "Customer contact email address"
        }
      },
      "required": ["name"]
    },
    "line_items": {
      "type": "array",
      "description": "Individual items/services on the invoice",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Item or service description"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units",
            "minimum": 0
          },
          "unit_price": {
            "type": "number",
            "description": "Price per unit",
            "minimum": 0
          },
          "discount": {
            "type": "number",
            "description": "Discount amount or percentage",
            "minimum": 0
          },
          "tax_rate": {
            "type": "number",
            "description": "Tax rate as percentage (e.g., 18 for 18%)",
            "minimum": 0,
            "maximum": 100
          },
          "line_total": {
            "type": "number",
            "description": "Total amount for this line item",
            "minimum": 0
          }
        },
        "required": ["description", "quantity", "unit_price", "line_total"]
      }
    },
    "subtotal": {
      "type": "number",
      "description": "Sum of all line items before tax and discounts",
      "minimum": 0
    },
    "tax_amount": {
      "type": "number",
      "description": "Total tax amount",
      "minimum": 0
    },
    "discount_amount": {
      "type": "number",
      "description": "Total discount applied",
      "minimum": 0
    },
    "total_amount": {
      "type": "number",
      "description": "Final amount due",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "description": "Currency code (ISO 4217)",
      "enum": ["USD", "EUR", "GBP", "INR", "JPY", "CNY", "AUD", "CAD"],
      "default": "USD"
    },
    "payment_terms": {
      "type": "string",
      "description": "Payment terms (e.g., 'Net 30', 'Due on receipt')"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or terms and conditions"
    }
  },
  "required": [
    "invoice_number",
    "invoice_date",
    "vendor",
    "customer",
    "line_items",
    "total_amount",
    "currency"
  ]
}
